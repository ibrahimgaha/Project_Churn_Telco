# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
*.manifest
*.spec


# --- Virtual Environments ---
venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/


# --- Environment Variables (NEVER push secrets!) ---
.env
.env.local
.env.*.local
*.secret
secrets.yaml
secrets.json


# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
*.ipynb_checkpoints


# --- Data Files (too large for git) ---
*.csv
*.tsv
*.parquet
*.feather
*.pkl
*.pickle
*.h5
*.hdf5
*.json
data/raw/
data/processed/
data/interim/
data/external/


# --- ML Models & Artifacts ---
*.model
*.joblib
*.onnx
*.pb
saved_models/
models/


# --- MLflow ---
mlruns/
mlartifacts/
.mlflow/


# --- DVC ---
.dvc/cache/
.dvc/tmp/
.dvc/plots/
*.dvc


# --- Docker ---
.docker/


# --- React / Node (Frontend) ---
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.next/
.cache/
*.tsbuildinfo


# --- FastAPI ---
.pytest_cache/
htmlcov/
.coverage
coverage.xml


# --- OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# --- IDE & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace


# --- Logs ---
*.log
logs/
log/


# --- Test & Coverage ---
.pytest_cache/
.coverage
htmlcov/
test-results/


# --- Misc ---
*.tmp
*.temp
*.bak
.cache/